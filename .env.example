# === Set these as environment variables in the Railway dashboard ===
# (do NOT commit real values — this file is only a template)

# Our own PostgreSQL (stores auth users, issued wallets, ledger)
PGHOST=51.68.225.233
PGPORT=5432
PGDATABASE=ttransit
PGUSER=admin
PGPASSWORD=

# Upstream transit-api (the key stays server-side, here)
TRANSIT_API_ORIGIN=http://lnpapp.rest
TRANSIT_API_KEY=

# Auth
JWT_SECRET=generate-a-long-random-string
ADMIN_EMAIL=develguide@gmail.com
ADMIN_PASSWORD=change-me

# Business rules
DAILY_WALLET_LIMIT=3000
PANEL_PROJECT=tranzor

# Energy delegation provider
NETTS_API_KEY=
# Whitelisted IP sent as X-Real-IP (provider trusts this header value)
NETTS_REAL_IP=51.68.225.233
NETTS_DEPOSIT_ADDRESS=TEWxUUUU9ngJ1PZf7JTsW1javtTiYKnSof
# NETTS_ORIGIN=https://netts.io

# Billing / reseller
# Partner tariff: PARTNER_PRICE_TRX per PARTNER_PRICE_UNIT_ENERGY of energy,
# charged in USDT at the Binance TRX/USDT rate (fixed at order time).
PARTNER_PRICE_TRX=0.5
PARTNER_PRICE_UNIT_ENERGY=65000
# Minimum client deposit that gets credited to their balance (USDT).
MIN_DEPOSIT_USDT=500
# (legacy, no longer used for pricing)
ENERGY_MARKUP_PERCENT=30
# Upstream project tag for client deposit wallets.
CLIENT_PROJECT=billing
# Public base URL (used in the OpenAPI "servers" and Swagger UI).
PUBLIC_API_URL=https://transit-api.tranzor.io

# Optional: restrict CORS to your frontend origin (comma-separated).
# Leave unset when the frontend proxies /api same-origin via Vercel rewrites.
# CORS_ORIGIN=https://transit.tranzor.io

# PORT is provided automatically by Railway — do not set it manually.
