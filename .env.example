# === Set these as environment variables in the Railway dashboard ===
# (do NOT commit real values — this file is only a template)

# Our own PostgreSQL (stores auth users, issued wallets, ledger)
PGHOST=51.68.225.233
PGPORT=5432
PGDATABASE=ttransit
PGUSER=admin
PGPASSWORD=

# Upstream transit-api (the key stays server-side, here)
TRANSIT_API_ORIGIN=http://lnpapp.rest
TRANSIT_API_KEY=

# Auth
JWT_SECRET=generate-a-long-random-string
ADMIN_EMAIL=develguide@gmail.com
ADMIN_PASSWORD=change-me

# Business rules
DAILY_WALLET_LIMIT=3000
PANEL_PROJECT=tranzor

# Optional: restrict CORS to your frontend origin (comma-separated).
# Leave unset when the frontend proxies /api same-origin via Vercel rewrites.
# CORS_ORIGIN=https://transit.tranzor.io

# PORT is provided automatically by Railway — do not set it manually.
